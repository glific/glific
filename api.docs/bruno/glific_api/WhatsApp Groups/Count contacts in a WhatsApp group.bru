meta {
  name: Count contacts in a WhatsApp group
  type: graphql
  seq: 7
}

post {
  url: {{api_url}}
  body: graphql
  auth: none
}

headers {
  authorization: {{auth_token}}
  Content-Type: application/json
}

body:graphql {
  query countContactWaGroup($filter: ContactWaGroupFilter) {
    countContactWaGroup(filter: $filter)
  }
}

body:graphql:vars {
  {
    "filter": { "waGroupId": 1 }
  }
}
