                "name": "Text to Speech",
                "localization": {
                    "hi": {
                        "c95c4d52-703f-4334-b3f1-98d466268b56": {
                            "text": [
                                "एक टेक्स्ट संदेश भेजें और उसे वॉइस नोट के रूप में वापस पाएं।"
                            ]
                        },
                        "b6fee2c0-132d-435c-88f4-62f2d19c96d8": {
                            "text": [
                                "क्षमा करें, हम वॉइस नोट नहीं बना सके। कृपया पुनः प्रयास करें।"
                            ]
                        }
                    },
                    "ta": {
                        "c95c4d52-703f-4334-b3f1-98d466268b56": {
                            "text": [
                                "ஒரு உரை செய்தியை அனுப்பி அதை குரல் குறிப்பாகப் பெறுங்கள்."
                            ]
                        },
                        "b6fee2c0-132d-435c-88f4-62f2d19c96d8": {
                            "text": [
                                "மன்னிக்கவும், குரல் குறிப்பை உருவாக்க முடியவில்லை. மீண்டும் முயற்சிக்கவும்."
                            ]
                        }
                    },
                    "mr": {
                        "c95c4d52-703f-4334-b3f1-98d466268b56": {
                            "text": [
                                "एक मजकूर संदेश पाठवा आणि तो व्हॉइस नोट म्हणून परत मिळवा."
                            ]
                        },
                        "b6fee2c0-132d-435c-88f4-62f2d19c96d8": {
                            "text": [
                                "क्षमस्व, आम्ही व्हॉइस नोट तयार करू शकलो नाही. कृपया पुन्हा प्रयत्न करा."
                            ]
                        }
                    },
                    "kn": {
                        "c95c4d52-703f-4334-b3f1-98d466268b56": {
                            "text": [
                                "ಪಠ್ಯ ಸಂದೇಶವನ್ನು ಕಳುಹಿಸಿ ಮತ್ತು ಅದನ್ನು ಧ್ವನಿ ಟಿಪ್ಪಣಿಯಾಗಿ ಹಿಂಪಡೆಯಿರಿ."
                            ]
                        },
                        "b6fee2c0-132d-435c-88f4-62f2d19c96d8": {
                            "text": [
                                "ಕ್ಷಮಿಸಿ, ಧ್ವನಿ ಟಿಪ್ಪಣಿಯನ್ನು ರಚಿಸಲು ಸಾಧ್ಯವಾಗಲಿಲ್ಲ. ದಯವಿಟ್ಟು ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ."
                            ]
                        }
                    },
                    "gu": {
                        "c95c4d52-703f-4334-b3f1-98d466268b56": {
                            "text": [
                                "એક ટેક્સ્ટ સંદેશ મોકલો અને તેને વૉઇસ નોટ તરીકે પાછો મેળવો."
                            ]
                        },
                        "b6fee2c0-132d-435c-88f4-62f2d19c96d8": {
                            "text": [
                                "માફ કરશો, અમે વૉઇસ નોટ બનાવી શક્યા નથી. કૃપા કરીને ફરી પ્રયાસ કરો."
                            ]
                        }
                    },
                    "bn": {
                        "c95c4d52-703f-4334-b3f1-98d466268b56": {
                            "text": [
                                "একটি টেক্সট বার্তা পাঠান এবং এটি ভয়েস নোট হিসাবে ফেরত পান।"
                            ]
                        },
                        "b6fee2c0-132d-435c-88f4-62f2d19c96d8": {
                            "text": [
                                "দুঃখিত, আমরা ভয়েস নোট তৈরি করতে পারিনি। অনুগ্রহ করে আবার চেষ্টা করুন।"
                            ]
                        }
                    },
                    "es": {
                        "c95c4d52-703f-4334-b3f1-98d466268b56": {
                            "text": [
                                "Envía un mensaje de texto y recíbelo como una nota de voz."
                            ]
                        },
                        "b6fee2c0-132d-435c-88f4-62f2d19c96d8": {
                            "text": [
                                "Lo sentimos, no pudimos generar la nota de voz. Por favor, inténtalo de nuevo."
                            ]
                        }
                    },
                    "en": {
                        "c95c4d52-703f-4334-b3f1-98d466268b56": {
                            "text": [
                                "Send a text message and get it back as a voice note."
                            ]
                        },
                        "b6fee2c0-132d-435c-88f4-62f2d19c96d8": {
                            "text": [
                                "Sorry, we could not generate the voice note. Please try again."
                            ]
                        }
                    }
